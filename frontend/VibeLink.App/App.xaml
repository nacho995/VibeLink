<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:VibeLink.App"
             xmlns:helpers="clr-namespace:VibeLink.App.Helpers"
             x:Class="VibeLink.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters disponibles globalmente en toda la app -->
            <helpers:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <helpers:CategoryColorConverter x:Key="CategoryColorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
