<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VibeLink.App.Views.ProfilePage"
             Title="Mi Perfil"
             BackgroundColor="#1a1a2e">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="18">

            <!-- Avatar -->
            <Border StrokeShape="RoundRectangle 60"
                    HeightRequest="120" WidthRequest="120"
                    HorizontalOptions="Center"
                    StrokeThickness="3" Stroke="#e94560">
                <Image Source="{Binding AvatarUrl}"
                       Aspect="AspectFill"
                       HeightRequest="120" WidthRequest="120" />
            </Border>

            <!-- Username y Email (solo lectura) -->
            <Label Text="{Binding Username}" FontSize="22" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center" />
            <Label Text="{Binding Email}" FontSize="13" TextColor="#8899aa"
                   HorizontalOptions="Center" />

            <!-- Badge Premium -->
            <Border BackgroundColor="{Binding IsPremium, Converter={StaticResource InvertedBoolConverter}}"
                    IsVisible="{Binding IsPremium}"
                    StrokeShape="RoundRectangle 15" Padding="10,5"
                    Stroke="Gold" HorizontalOptions="Center">
                <Label Text="PREMIUM" TextColor="Gold" FontAttributes="Bold" FontSize="12" />
            </Border>

            <Label Text="{Binding SwipesLeft, StringFormat='Swipes restantes: {0}'}"
                   TextColor="#8899aa" FontSize="13" HorizontalOptions="Center" />

            <BoxView HeightRequest="1" Color="#0f3460" />

            <!-- Bio -->
            <Label Text="Bio" TextColor="#8899aa" FontSize="13" />
            <Border BackgroundColor="#16213e" Stroke="#0f3460" StrokeShape="RoundRectangle 10" Padding="5">
                <Editor Text="{Binding Bio}" TextColor="White" HeightRequest="80"
                        PlaceholderColor="#556677" Placeholder="Cuéntanos sobre ti..." />
            </Border>

            <!-- Avatar URL -->
            <Label Text="URL del avatar" TextColor="#8899aa" FontSize="13" />
            <Border BackgroundColor="#16213e" Stroke="#0f3460" StrokeShape="RoundRectangle 10" Padding="5">
                <Entry Text="{Binding AvatarUrl}" TextColor="White"
                       PlaceholderColor="#556677" Placeholder="https://..." Keyboard="Url" />
            </Border>

            <!-- Género -->
            <Label Text="Género" TextColor="#8899aa" FontSize="13" />
            <Border BackgroundColor="#16213e" Stroke="#0f3460" StrokeShape="RoundRectangle 10" Padding="5">
                <Picker ItemsSource="{Binding GenderOptions}"
                        SelectedIndex="{Binding SelectedGenderIndex}"
                        TextColor="White" />
            </Border>

            <!-- Fecha nacimiento -->
            <Label Text="Fecha de nacimiento" TextColor="#8899aa" FontSize="13" />
            <DatePicker Date="{Binding DateOfBirth}" TextColor="White" />

            <!-- Error -->
            <Label Text="{Binding ErrorMessage}" TextColor="#ff6b6b" FontSize="13"
                   IsVisible="{Binding ShowError}" HorizontalOptions="Center" />

            <!-- Guardar -->
            <Button Text="Guardar Cambios" Command="{Binding SaveProfileCommand}"
                    BackgroundColor="#e94560" TextColor="White" FontAttributes="Bold"
                    CornerRadius="10" HeightRequest="50"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#e94560" />

            <!-- Logout -->
            <Button Text="Cerrar Sesión" Command="{Binding LogoutCommand}"
                    BackgroundColor="Transparent" TextColor="#ff6b6b"
                    FontAttributes="Bold" CornerRadius="10" HeightRequest="45" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
