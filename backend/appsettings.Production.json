{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=vibelink;Username=vibelink;Password=${DB_PASSWORD}"
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "VibeLink",
    "Audience": "VibelinkUsers",
    "ExpirationDays": 30
  },
  "Stripe": {
    "SecretKey": "${STRIPE_SECRET_KEY}",
    "WebhookSecret": "${STRIPE_WEBHOOK_SECRET}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": "${CORS_ORIGINS}"
  }
}
